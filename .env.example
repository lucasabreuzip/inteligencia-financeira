OPENAI_API_KEY=sk-sua-key
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ORIGINS=http://localhost:3000
MAX_UPLOAD_MB=25
DATA_DIR=./data
UPLOAD_DIR=./data/uploads

# Postgres
DATABASE_URL=postgresql://finance_user:CHANGE_ME@db:5432/finance_db
POSTGRES_USER=finance_user
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=finance_db

# Rate limiting slowapi. Formato: <N>/minute.
CHAT_RATE_LIMIT=20/minute
UPLOAD_RATE_LIMIT=5/minute

# Concorrencia e pool de conexões
MAX_CONCURRENT_PIPELINES=5
DB_POOL_MIN=2
DB_POOL_MAX=20

# Auth por API key compartilhada
API_KEY=

# Langfuse
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=
#LANGFUSE_HOST=https://us.cloud.langfuse.com
#LANGFUSE_HOST=https://eu.cloud.langfuse.com